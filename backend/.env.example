# ===================================
# CONFIGURAÇÕES DO SERVIDOR
# ===================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ===================================
# BANCO DE DADOS POSTGRESQL
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_saas
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_DIALECT=postgres

# ===================================
# JWT & SEGURANÇA
# ===================================
JWT_SECRET=sua_chave_secreta_super_segura_aqui_mude_isso
JWT_EXPIRES_IN=7d

# ===================================
# WEBHOOK DIGGION (CHECKOUT)
# ===================================
DIGGION_WEBHOOK_SECRET=sua_chave_webhook_diggion
DIGGION_PRODUCT_ID=seu_product_id

# ===================================
# ADMIN PADRÃO (CRIADO NO SETUP)
# ===================================
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=Admin@123456

# ===================================
# CORS & FRONTEND URL
# ===================================
FRONTEND_URL=http://localhost:5173

# ===================================
# BAILEYS / WHATSAPP
# ===================================
# Diretório onde as sessões do WhatsApp serão salvas
AUTH_SESSIONS_DIR=./auth_sessions

# ===================================
# SISTEMA ANTI-BAN
# ===================================
# Limites por idade de conta (dias)
ANTI_BAN_NEW_ACCOUNT_DAYS=7
ANTI_BAN_MEDIUM_ACCOUNT_DAYS=30

# Limites diários de mensagens
ANTI_BAN_NEW_DAILY_LIMIT=50
ANTI_BAN_MEDIUM_DAILY_LIMIT=150
ANTI_BAN_OLD_DAILY_LIMIT=500

# Delays entre mensagens (segundos)
ANTI_BAN_NEW_DELAY_MIN=15
ANTI_BAN_NEW_DELAY_MAX=45
ANTI_BAN_MEDIUM_DELAY_MIN=8
ANTI_BAN_MEDIUM_DELAY_MAX=20
ANTI_BAN_OLD_DELAY_MIN=3
ANTI_BAN_OLD_DELAY_MAX=10

# Pausas inteligentes
ANTI_BAN_BURST_MIN=5
ANTI_BAN_BURST_MAX=20
ANTI_BAN_PAUSE_MIN=120
ANTI_BAN_PAUSE_MAX=300

# Horário comercial (9h às 21h)
ANTI_BAN_START_HOUR=9
ANTI_BAN_END_HOUR=21

# Taxa de erro para detecção de ban (%)
ANTI_BAN_ERROR_THRESHOLD=70

# ===================================
# UPLOADS & STORAGE
# ===================================
UPLOADS_DIR=./uploads
MAX_FILE_SIZE=10485760
