# ========================
# DATABASE
# ========================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/globaldisparos"

# ========================
# JWT
# ========================
JWT_SECRET=seu_jwt_secret_super_seguro_aqui_minimo_32_chars
JWT_EXPIRES_IN=7d

# ========================
# REDIS (opcional — sistema funciona sem Redis)
# ========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# EVOLUTION API
# ========================
EVOLUTION_API_URL=http://127.0.0.1:8081
EVOLUTION_API_KEY=myfKey123456789

# ========================
# WEBHOOK URL (como a Evolution chama o backend)
# Dev local com Docker: use host.docker.internal
# VPS/Produção: use o domínio real
# ========================
WEBHOOK_URL=http://host.docker.internal:3001/api/webhook/evolution

# ========================
# SERVIDOR
# ========================
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ========================
# RATE LIMITING
# ========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
